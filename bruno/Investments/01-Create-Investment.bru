meta {
  name: Create Investment (Investor)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/investments
  body: json
}

headers {
  Authorization: Bearer {{accessToken}}
}

body:json {
  {
    "amount": 5000,
    "projectId": 1
  }
}

tests {
  test("Status is 201", function() {
    expect(res.getStatus()).to.equal(201);
  });
  test("Investment has amount", function() {
    expect(res.body).to.have.property('amount');
    expect(res.body).to.have.property('investedAt');
  });
}

