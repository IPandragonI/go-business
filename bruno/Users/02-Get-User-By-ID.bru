meta {
  name: Get User by ID
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/users/1
}

headers {
  Authorization: Bearer {{accessToken}}
}

tests {
  test("Status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("User has properties", function() {
    expect(res.body).to.have.property('id');
    expect(res.body).to.have.property('email');
  });
}

